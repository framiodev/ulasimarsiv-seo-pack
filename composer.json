{
    "name": "ulasimarsiv/seo-pack",
    "version": "1.1.5",
    "description": "Gelişmiş Flarum SEO: Meta Etiketleri, Sitemap ve Google Indexing API Entegrasyonu.",
    "type": "flarum-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "Ulaşım Arşiv Team",
            "email": "info@ulasimarsiv.com"
        }
    ],
    "autoload": {
        "psr-4": {
